# ──────────────────────────────────────────────────────────────────────────────
# AutoApply — Environment Variable Template
# Copy this file to `.env` and fill in your real values.
# NEVER commit your real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Google Drive / Docs (for CV generation and reading your Master CV)
GOOGLE_APPLICATION_CREDENTIALS=secrets/google_service_account.json
GOOGLE_DRIVE_BANK_FOLDER_ID=your_google_drive_folder_id_here
GOOGLE_MASTER_CV_DOC_ID=your_master_cv_doc_id_here
GOOGLE_ACCOMPLISHMENTS_SHEET_ID=your_accomplishments_sheet_id_here
GOOGLE_GENERATED_CVS_FOLDER_ID=your_generated_cvs_folder_id_here

# Groq LLM API — get your key from https://console.groq.com
# IMPORTANT: Rotate your key immediately if it is ever committed to git.
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# Job Portal APIs for Live Data (Agent 1)
# ──────────────────────────────────────────────────────────────────────────────

# Adzuna API — Get free API credentials from https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# SerpAPI — Get API key from https://serpapi.com (has free tier)
SERPAPI_KEY=sVSVg3JeGBAWoTSBgYZUL2tZ

# ──────────────────────────────────────────────────────────────────────────────
# Job Portal Scraping Configuration (Anti-Ban Measures)
# ──────────────────────────────────────────────────────────────────────────────

# Enable/disable specific scrapers
ENABLE_NAUKRI_SCRAPING=true
ENABLE_CUTSHORT_SCRAPING=true
ENABLE_OTTA_SCRAPING=false
ENABLE_BAYT_SCRAPING=false

# Scraping limits
SCRAPING_CONCURRENT_LIMIT=1
SCRAPING_CACHE_HOURS=24

# ──────────────────────────────────────────────────────────────────────────────
# Pipeline behaviour flags
# ──────────────────────────────────────────────────────────────────────────────

# MANUAL_MODE=true  → All emails and applications are logged for manual review (default)
# No automatic Gmail or Playwright integration - user reviews and sends manually
MANUAL_MODE=true

# USE_MOCK_JOBS=true  → Agent 1 uses 4 hardcoded fake jobs (safe for testing)
# USE_MOCK_JOBS=false → Agent 1 uses the real job scraper adapter (Adzuna, SerpAPI, etc.)
USE_DEMO_DATA=false
USE_MOCK_JOBS=false
